---

---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-logo">[void.log]</span>
      <p class="footer-tagline">Ideias que não cabem num tweet.</p>
    </div>

    <div class="footer-links">
      <a
        href="https://github.com/RicardoFrancoDelgado"
        class="footer-link"
        target="_blank"
        rel="noopener">GitHub</a
      >
      <a
        href="https://www.linkedin.com/in/ricardofrancodelgado-dev/"
        class="footer-link"
        target="_blank"
        rel="noopener">LinkedIn</a
      >
      <a href="/rss.xml" class="footer-link">RSS</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {new Date().getFullYear()} void.log — feito com Astro</span>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    padding: 40px 24px 24px;
  }

  .footer-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--accent-blue);
    display: block;
    margin-bottom: 6px;
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--text-faint);
  }

  .footer-links {
    display: flex;
    gap: 20px;
    align-items: center;
  }

  .footer-link {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color 0.15s;
  }
  .footer-link:hover {
    color: var(--text);
  }

  .footer-bottom {
    max-width: 860px;
    margin: 24px auto 0;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    font-size: 0.78rem;
    color: var(--text-faint);
  }
</style>
